DROP TABLE temp_ft;
/* cloning 5000 triples from the foreign table */
CALL
    rdf_fdw_clone_table(
        foreign_table => 'public.ft',
        target_table  => 'public.ft_clone',
        fetch_size => 5000,
        create_table => true,
        verbose => true
    );
INFO:  Target TABLE "public.ft_clone" created based on FOREIGN TABLE "public.ft":

  CREATE TABLE public.ft_clone AS SELECT * FROM public.ft WITH NO DATA;

INFO:  

== Parameters ==

foreign_table: 'ft'
target_table: 'public.ft_clone'
create_table: 'true'
fetch_size: 5000
begin_offset: 0
max_records: 0
ordering_column: 'NOT SET'
ordering sparql variable: '?s'
sort_order: 'ASC'

INFO:  [0 - 5000]: 5000 records inserted
DROP TABLE ft_clone;
/* describing subject with 5000 triples */
CREATE UNLOGGED TABLE temp_describe AS
SELECT subject, predicate, object
FROM sparql.describe('virtuoso', 'DESCRIBE <https://www.uni-muenster.de>')
ORDER BY object::bigint;
SELECT count(*) FROM temp_describe;
 count 
-------
     0
(1 row)

SELECT * FROM temp_describe
WHERE 
  subject = '<https://www.uni-muenster.de>'::rdfnode AND
  object BETWEEN 2500::rdfnode AND 2510::rdfnode;
 subject | predicate | object 
---------+-----------+--------
(0 rows)

DROP TABLE temp_describe;
/* deleting 5000 triples */
DELETE FROM ft;
SELECT * FROM ft;
 subject | predicate | object 
---------+-----------+--------
(0 rows)

DROP SERVER virtuoso CASCADE;
NOTICE:  drop cascades to 2 other objects
DETAIL:  drop cascades to foreign table ft
drop cascades to user mapping for postgres on server virtuoso
