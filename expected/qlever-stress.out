/* describing subject with one million triples */
CREATE UNLOGGED TABLE temp_describe AS
SELECT subject, predicate, object
FROM sparql.describe('qlever', 'DESCRIBE <https://www.uni-muenster.de>')
ORDER BY object::bigint;
