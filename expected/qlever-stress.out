DROP TABLE temp_ft;
/* cloning one million triples from the foreign table */
CALL
    rdf_fdw_clone_table(
        foreign_table => 'public.ft',
        target_table  => 'public.ft_clone',
        fetch_size => 100000,
        create_table => true,
        verbose => true
    );
